{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile for patients and doctors.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID matches auth.uid" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "language": { "type": "string", "enum": ["en", "ar"] },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "DoctorProfile": {
      "title": "Doctor Profile",
      "description": "Detailed professional info for doctors.",
      "type": "object",
      "properties": {
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "certifications": { "type": "array" },
        "bio": { "type": "string" },
        "fees": { "type": "number" },
        "rating": { "type": "number" },
        "location": { "type": "string" },
        "languages": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["specialty", "fees"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Information about a medical appointment.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "type": { "type": "string", "enum": ["video", "voice", "in-person"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "dateTime", "status", "type", "createdAt"]
    },
    "MedicalRecord": {
      "title": "Medical Record",
      "description": "A patient's medical history entry.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "diagnosis": { "type": "string" },
        "treatment": { "type": "string" },
        "attachments": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "diagnosis", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message within a chat room.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "attachments": { "type": "array" }
      },
      "required": ["senderId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Patient and Dr core profiles."
    },
    "/doctors/{doctorId}": {
      "schema": "DoctorProfile",
      "description": "Professional doctor details indexed by user CID."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Scheduled appointments."
    },
    "/medicalRecords/{recordId}": {
      "schema": "MedicalRecord",
      "description": "Patient medical records."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages for consultation chats."
    }
  }
}
