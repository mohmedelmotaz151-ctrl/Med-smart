rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens never contain custom claims in this env, but we check for admin in various ways
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        ('email' in request.auth.token && (
          request.auth.token.email.lower().matches('.*admin.*') ||
          request.auth.token.email == 'admin@gcc-company.com' ||
          request.auth.token.email == 'mohmedelmotaz151@gmail.com'
        ))
      ); 
    }

    // --- Users ---
    // /users/{userId}
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'language', 'phoneNumber', 'updatedAt']) && 
         incoming().updatedAt == request.time && incoming().uid == existing().uid && incoming().role == existing().role)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['patient', 'doctor', 'admin'] &&
             data.createdAt == (resource == null ? request.time : resource.data.createdAt);
    }

    // --- Doctors ---
    match /doctors/{doctorId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(doctorId) && isValidDoctor(incoming()) && (
        resource == null || (incoming().updatedAt == request.time && incoming().diff(existing()).affectedKeys().hasAny(['specialty', 'fees', 'experience', 'bio', 'location', 'rating', 'languages', 'updatedAt']))
      );
    }

    function isValidDoctor(data) {
      return data.specialty is string && data.specialty.size() <= 100 &&
             data.fees is number && data.fees >= 0;
    }

    // --- Appointments ---
    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && (isOwner(existing().patientId) || isOwner(existing().doctorId));
      allow list: if isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid);
      allow create: if isSignedIn() && isValidAppointment(incoming()) && isOwner(incoming().patientId) && isValidId(appointmentId);
      allow update: if isSignedIn() && isValidAppointment(incoming()) && (
        (isOwner(existing().patientId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'updatedAt']) && incoming().status == 'cancelled') ||
        (isOwner(existing().doctorId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'updatedAt']))
      ) && incoming().updatedAt == request.time;
    }

    function isValidAppointment(data) {
      return data.patientId is string && data.patientId.size() <= 128 &&
             data.doctorId is string && data.doctorId.size() <= 128 &&
             data.status in ['pending', 'confirmed', 'cancelled', 'completed'] &&
             data.createdAt == (resource == null ? request.time : resource.data.createdAt);
    }

    // --- Medical Records ---
    match /medicalRecords/{recordId} {
      allow get: if isSignedIn() && (isOwner(existing().patientId) || isOwner(existing().doctorId));
      allow list: if isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid);
      allow create: if isSignedIn() && isOwner(incoming().doctorId) && isValidRecord(incoming()) && isValidId(recordId);
      // Records are immutable per standard practice
      allow update, delete: if false;
    }

    function isValidRecord(data) {
      return data.patientId is string && data.doctorId is string && 
             data.diagnosis is string && data.diagnosis.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // --- Chats ---
    match /chats/{chatId} {
      // In this simplified version, chatId is docId or 'ai'
      // For real chats, we'd have participants subcollection
      allow read: if isSignedIn(); // Simplified for now since chatId 'ai' is public logic
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(incoming().senderId) && isValidMessage(incoming());
      }
    }

    function isValidMessage(data) {
      return data.senderId is string && data.text is string && 
             data.text.size() <= 5000 && data.timestamp == request.time;
    }

    // --- GCC Dynamic Media ---
    match /gcc_dynamic_media/{mediaId} {
      allow read: if true;
      allow create: if isAdmin() && isValidMedia(incoming()) && isValidId(mediaId);
      allow update: if isAdmin() && isValidMedia(incoming()) && isValidId(mediaId);
      allow delete: if isAdmin() && isValidId(mediaId);
    }

    function isValidMedia(data) {
      return data.titleEn is string && data.titleEn.size() <= 200 &&
             data.titleAr is string && data.titleAr.size() <= 200 &&
             data.descriptionEn is string && data.descriptionEn.size() <= 5000 &&
             data.descriptionAr is string && data.descriptionAr.size() <= 5000 &&
             data.category is string && data.category.size() <= 100 &&
             data.type is string && data.type.size() <= 100 &&
             data.imageUrls is list && data.imageUrls.size() <= 100 &&
             (data.imageUrls.size() == 0 || data.imageUrls[0] is string);
    }

    // --- Inquiries / Quote Requests ---
    match /inquiries/{inquiryId} {
      allow get: if isAdmin() || (isSignedIn() && existing().userEmail == request.auth.token.email);
      allow list: if isAdmin() || 
                     (isSignedIn() && resource.data.userEmail == request.auth.token.email) ||
                     (resource.data.ticketId != null);
      allow create: if isValidInquiry(incoming());
      allow update, delete: if isAdmin();
    }

    function isValidInquiry(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.email is string && data.email.size() <= 200 &&
             data.ticketId is string && data.ticketId.size() <= 100 &&
             data.status in ['new', 'under_review', 'priced', 'completed'];
    }
  }
}
